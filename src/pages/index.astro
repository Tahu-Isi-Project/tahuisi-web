---
import Layout from "@layouts/Layout.astro";
import Slider from "@features/index/components/Slider.tsx";
import HeroSection from "@features/index/components/HeroSection.astro";
import AboutSection from "@features/index/components/AboutSection.astro";
import LatestNews from "@features/index/components/LatestNews.astro";
import headlines from "@features/index/data/sample-headlines.json"

const sampleHeadlines = headlines;
---

<Layout title="Home">
  <HeroSection />
  <AboutSection />
  <Slider />
  <LatestNews items={sampleHeadlines} />
</Layout>
