---
import Layout from "@layouts/Layout.astro";
import SliderSection from "@root/src/features/index/components/SliderSection.tsx";
import HeroSection from "@features/index/components/HeroSection.astro";
import AboutSection from "@features/index/components/AboutSection.astro";
import LatestNewsSection from "@features/index/components/LatestNewsSection.astro";
import headlines from "@features/index/data/sample-headlines.json"
import CalendarSection from "../features/index/components/CalendarSection.tsx";

const sampleHeadlines = headlines;
---

<Layout title="Home">
  <HeroSection />
  <AboutSection />
  <SliderSection />
  <LatestNewsSection items={sampleHeadlines} />
  <CalendarSection client:idle />
</Layout>
