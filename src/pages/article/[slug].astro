---
export const config = {
  isr: { expiration: false },
};

const { slug } = Astro.params;

const response = await fetch(`${import.meta.env.BACKEND_URL}/content/article/${slug}`, {
  method: "GET",
  headers: {
    Authorization: `Bearer ${import.meta.env.API_SECRET}`,
    "Content-Type": "application/json",
  },
});

if (!response.ok) {
  return new Response(
    JSON.stringify({ message: `Article not found for ${slug}` }),
    { status: 404 }
  );
}

const article = await response.json();
