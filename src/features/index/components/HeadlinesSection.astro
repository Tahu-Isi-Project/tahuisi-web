---
import Image from "astro/components/Image.astro";
import ArrowButton from "@components/ArrowButton.tsx";
import { z } from "astro/zod";
import getThumbHashUrl from "@common/utils/thumbhash";

export const newsHeadlineSchema = z.array(z.object({
  title: z.string(),
  slug: z.string(),
  excerpt: z.string(),
  rawThumbnailSrc: z.nullable(z.url()),
  thumbnailAlt: z.nullable(z.string()),
  thumbhash: z.nullable(z.string()),
}));

const url = `${process.env.BE_ENDPOINT}/article/headlines`;

const res = await fetch(url, {
  method: "GET",
  headers: {
    "x-internal-secret": process.env.INTERNAL_SECRET || ""
  }
});

const json = await res.json();
const rawHeadlines = newsHeadlineSchema.parse(json);

const headlines = rawHeadlines.map((item) => ({
  title: item.title,
  slug: item.slug,
  excerpt: item.excerpt,
  thumbnailSrc: item.rawThumbnailSrc,
  thumbnailAlt: item.thumbnailAlt,
  placeholderUrl: item.thumbhash ? getThumbHashUrl(item.thumbhash) : "",
}));

const thumbnailWidth: number = 350;
---

<section class="font-[ArgentumSans] my-10 text-black mx-auto max-w-362">
  <div class="mb-8">
    <div class="text-6xl font-bold">Articles</div>
    <div class="w-1/2">
      <div class="flex w-full mt-4 h-3">
        <div class="bg-[#EE6983] flex-2"></div>
        <div class="bg-[#FFC4C4] flex-2"></div>
        <div class="bg-[#FCF5EE] flex-6"></div>
      </div>
    </div>
  </div>

  <div
    id="headlines-container"
    class="flex flex-row gap-8 p-4 snap-x snap-mandatory overflow-x-hidden"
  >
    {
      headlines.map((item) => (
        <a
          href={`/article/${item.slug}`}
          class={`block relative group aspect-2/3 w-87.5 shrink-0 overflow-hidden rounded-xl hover cursor-pointer shadow-[15px_15px_30px_0px_rgba(0,0,0,0.25)]`}
        >
          <img 
            src={item.placeholderUrl} 
            alt=""
            aria-hidden="true"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <Image
            src={item.thumbnailSrc || ""}
            alt={item.thumbnailAlt}
            width={160}
            height={200}
            class="absolute w-full h-full object-cover transition-all duration-500 opacity-0 group-hover:scale-110"
            format="webp"
            quality="low"
            loading="lazy"
            decoding="async"
            onload="this.classList.remove('opacity-0')"
          />
          <div class="absolute inset-0 z-10 bg-linear-to-t from-black/90 via-black/40 to-transparent" />
          <div class="absolute bottom-0 p-6 text-white w-full z-20">
            <h3 class="text-[1.5rem] font-bold leading-tight mb-2 line-clamp-2">
              {item.title}
            </h3>
            <p class="text-[1rem] font-[Allerta] text-gray-200 line-clamp-3">
              {item.excerpt}
            </p>
          </div>
        </a>
      ))
    }
  </div>

  <div class="flex items-center mt-8">
    <div class="px-5">
      <ArrowButton
        client:load
        size={40}
        direction="Left"
        {thumbnailWidth}
      />
    </div>
    <div class="px-5">
      <ArrowButton
        client:load
        size={40}
        direction="Right"
        {thumbnailWidth}
      />
    </div>
    <div class="flex-1">
      <div class="flex w-full h-4">
        <div class="bg-[#EE6983] w-1/5"></div>
        <div class="bg-[#FFC4C4] flex-1"></div>
      </div>
    </div>
  </div>
</section>

<script>
  function moveHeadlines(direction: "Left" | "Right", thumbnailWidth: number) {
    const container = document.getElementById("headlines-container");

    const offset = 30;

    if (container) {
      const scrollAmount = direction === "Right" ? thumbnailWidth + offset : -thumbnailWidth - offset;

      container.scrollBy({
        left: scrollAmount,
        behavior: "smooth",
      });
    }
  }

  window.moveHeadlines = moveHeadlines;
</script>
