---
export interface Props {
  content: string;
}

const { content } = Astro.props;
---

<div class="prose prose-slate lg:prose-xl max-w-none
               prose-headings:font prose-headings:tracking-tight
               prose-a:text-blue-600 hover:prose-a:text-blue-500
               prose-img:rounded-xl prose-img:shadow-md prose-img:w-full
               prose-blockquote:border-l-4 prose-blockquote:border-slate-300 prose-blockquote:italic"
  set:html={content}
/>
